@model ZooApp.Models.Animal

@{
    ViewData["Title"] = "Delete Animal";
}

<h1>Delete Animal</h1>

<h3>Are you sure you want to delete this animal?</h3>

<hr />

<div class="mb-3">
    <strong>Id:</strong> @Model.Id
</div>

<div class="mb-3">
    <strong>Name:</strong> @Model.Name
</div>

<div class="mb-3">
    <strong>Species:</strong> @Model.Species
</div>

<div class="mb-3">
    <strong>Age:</strong> @Model.Age
</div>

<div class="mb-3">
    <strong>Category:</strong> @Model.Category?.Name
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back to List
    </a>
</form>