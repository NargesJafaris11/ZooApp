@model List<ZooApp.Models.Animal>

@{
    ViewData["Title"] = "Animals";
}

<h1>Animals</h1>

@await Component.InvokeAsync("AnimalStatistics")

<p>
    <a asp-action="Create" class="btn btn-primary">
        Add New Animal
    </a>
</p>

<partial name="_SearchForm" />

<partial name="_AnimalTable" model="Model" />

@section Footer
{
    <span>ZooApp - Animal overview page</span>
}