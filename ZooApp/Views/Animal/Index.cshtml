@model List<ZooApp.Models.Animal>

@{
    ViewData["Title"] = "Animals";
}

<h1>Animals</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Nieuw dier toevoegen
    </a>
</p>

<form asp-action="Index" method="get" class="row mb-3">

    <div class="col-md-3">
        <input type="text"
               name="searchString"
               value="@ViewBag.CurrentSearch"
               class="form-control"
               placeholder="Search by name..." />
    </div>

    <div class="col-md-3">
        <select name="categoryId" class="form-select">
            <option value="">All categories</option>

            @foreach (var category in ViewBag.Categories)
            {
                if (ViewBag.CurrentCategoryId != null && ViewBag.CurrentCategoryId == category.Id)
                {
                    <option value="@category.Id" selected>@category.Name</option>
                }
                else
                {
                    <option value="@category.Id">@category.Name</option>
                }
            }
        </select>
    </div>

    <div class="col-md-3">
        <select name="sortOrder" class="form-select">

            @if (ViewBag.CurrentSortOrder == "name_desc")
            {
                <option value="">Name A-Z</option>
                <option value="name_desc" selected>Name Z-A</option>
                <option value="age_asc">Age Low-High</option>
                <option value="age_desc">Age High-Low</option>
            }
            else if (ViewBag.CurrentSortOrder == "age_asc")
            {
                <option value="">Name A-Z</option>
                <option value="name_desc">Name Z-A</option>
                <option value="age_asc" selected>Age Low-High</option>
                <option value="age_desc">Age High-Low</option>
            }
            else if (ViewBag.CurrentSortOrder == "age_desc")
            {
                <option value="">Name A-Z</option>
                <option value="name_desc">Name Z-A</option>
                <option value="age_asc">Age Low-High</option>
                <option value="age_desc" selected>Age High-Low</option>
            }
            else
            {
                <option value="" selected>Name A-Z</option>
                <option value="name_desc">Name Z-A</option>
                <option value="age_asc">Age Low-High</option>
                <option value="age_desc">Age High-Low</option>
            }

        </select>
    </div>

    <div class="col-md-1">
        <button class="btn btn-primary" type="submit">
            Search
        </button>
    </div>

    <div class="col-md-2">
        <a asp-action="Index" class="btn btn-secondary">
            Reset
        </a>
    </div>

</form>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Species</th>
        <th>Age</th>
        <th>Category</th>
        <th>Actions</th>
    </tr>
    </thead>

    <tbody>

    @foreach (var animal in Model)
    {
        <tr>
            <td>@animal.Id</td>
            <td>@animal.Name</td>
            <td>@animal.Species</td>
            <td>@animal.Age</td>
            <td>@animal.Category?.Name</td>

            <td>
                <a asp-action="Details" asp-route-id="@animal.Id">Details</a> |
                <a asp-action="Edit" asp-route-id="@animal.Id">Edit</a> |
                <a asp-action="Delete" asp-route-id="@animal.Id">Delete</a>
            </td>

        </tr>
    }

    </tbody>

</table>